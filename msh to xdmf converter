msh = meshio.read("meshes/MF_cfg13_E_LoArm_conv.msh")
tri_blocks = [c.data for c in msh.cells if c.type == "triangle"]
all_tri = np.vstack(tri_blocks)

# Scale mm → m for SI units
meshio.Mesh(
    points=msh.points[:, :2] * 1e-3,
    cells={"triangle": all_tri},
).write("xdmf/cfg13.xdmf")

pts = msh.points * 1e-3
print(f"X: {pts[:,0].min()*1e3:.2f} to {pts[:,0].max()*1e3:.2f} mm")
print(f"Y: {pts[:,1].min()*1e3:.2f} to {pts[:,1].max()*1e3:.2f} mm")
print(f"Triangles: {len(all_tri)}")
